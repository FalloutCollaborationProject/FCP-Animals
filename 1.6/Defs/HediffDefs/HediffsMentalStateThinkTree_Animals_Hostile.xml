<?xml version="1.0" encoding="utf-8" ?>
<Defs>

    <!--__________ Hediffs __________-->

    <!--_____ Wild Animal Hediffs _____-->

    <!-- Spawn Hostile -->

    <HediffDef>
        <defName>FCP_Hediff_Spawn_Hostile_Animal</defName>
        <label>Hostile Animal</label>
        <description>Hostile Animal.</description>
        <descriptionShort>.</descriptionShort>
        <hediffClass>HediffWithComps</hediffClass>
        <defaultLabelColor>(0.9, 1.0, 0.35)</defaultLabelColor>
        <initialSeverity>10</initialSeverity>
        <comps>
            <li Class="FCP.Core.HediffCompProperties_HostileAnimal">
                <animalMentalState>FCP_Mental_State_Hostile_Animal</animalMentalState>
            </li>
        </comps>
    </HediffDef>

    <!--__________ Mental States __________-->

    <!-- Spawn Hostile -->

    <MentalStateDef ParentName="BaseMentalState">
        <defName>FCP_Mental_State_Hostile_Animal</defName>
        <stateClass>FCP.Core.MentalState_HostileAnimal</stateClass>
        <category>Aggro</category>
        <minTicksBeforeRecovery>99999999</minTicksBeforeRecovery>
        <inCaravanCanDo>true</inCaravanCanDo>
        <recoverFromSleep>false</recoverFromSleep>
        <recoverFromDowned>false</recoverFromDowned>
        <recoverFromCollapsingExhausted>false</recoverFromCollapsingExhausted>
    </MentalStateDef>

    <!--__________ Think Tree __________-->

    <!-- Spawn Hostile -->

    <ThinkTreeDef>
        <defName>FCP_Mental_State_Hostile_Animal_Think_Tree</defName>
        <thinkRoot Class="ThinkNode_Tagger">
            <tagToGive>InMentalState</tagToGive>
            <subNodes>
                <li Class="ThinkNode_ConditionalMentalState">
                    <state>FCP_Mental_State_Hostile_Animal</state>
                    <subNodes>
                        <li Class="ThinkNode_Priority">
                            <subNodes>
                                <li Class="ThinkNode_PrioritySorter">
                                    <subNodes>
                                        <li Class="JobGiver_GetFood">
                                            <minCategory>Hungry</minCategory>
                                        </li>
                                    </subNodes>
                                </li>
                                <li Class="FCP.Core.JobGiver_HostileAnimal">
                                    <maxProximityDistance>20</maxProximityDistance>
                                    <maxRetaliationDistance>40</maxRetaliationDistance>
                                </li>
                                <li Class="JobGiver_WanderAnywhere">
                                    <maxDanger>Deadly</maxDanger>
                                </li>
                            </subNodes>
                        </li>
                    </subNodes>
                </li>
            </subNodes>
        </thinkRoot>
    </ThinkTreeDef>

</Defs>