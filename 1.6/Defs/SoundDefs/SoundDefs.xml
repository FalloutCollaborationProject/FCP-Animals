    <!-- Deathclaw Call -->

    <SoundDef>
        <defName>FCP_Sound_Deathclaw_Call</defName>
        <context>MapOnly</context>
        <subSounds>
            <li>
                <grains>
                    <li Class="AudioGrain_Clip">
                        <clipPath>Deathclaw/FCP_Pawn_Deathclaw_Call</clipPath>
