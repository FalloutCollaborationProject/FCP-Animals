    <!--___ Yao Guai ___-->

    <!-- ThingDef -->

    <ThingDef ParentName="AnimalThingBase">
        <defName>FCP_Animal_Yao_Guai</defName>
        <label>Yao Guai</label>
        <devNote>Yao Guai - Mutated Bear</devNote>
        <description>A terrifying mutated bear, far larger and more aggressive than its pre-war ancestors. The name "Yao Guai" comes from the Chinese word for demon, and these apex predators live up to their fearsome reputation. Their thick hide provides excellent protection, and their ferocity makes them one of the most dangerous creatures in the wasteland.</description>
        <statBases>
            <MoveSpeed>5.5</MoveSpeed>
            <MarketValue>850</MarketValue>
            <ComfyTemperatureMin>-45</ComfyTemperatureMin>
            <ComfyTemperatureMax>55</ComfyTemperatureMax>
            <FilthRate>8</FilthRate>
            <ToxicEnvironmentResistance>0.85</ToxicEnvironmentResistance>
            <ArmorRating_Blunt>0.25</ArmorRating_Blunt>
            <ArmorRating_Sharp>0.20</ArmorRating_Sharp>
            <Wildness>0.95</Wildness>
        </statBases>
        <tools>
            <li>
                <label>left claw</label>
                <labelNoLocation>claw</labelNoLocation>
                <capacities>
                    <li>Cut</li>
                </capacities>
                <power>22.0</power>
                <cooldownTime>2</cooldownTime>
                <armorPenetration>0.35</armorPenetration>
                <linkedBodyPartsGroup>FrontLeftClaws</linkedBodyPartsGroup>
            </li>
            <li>
                <label>right claw</label>
                <labelNoLocation>claw</labelNoLocation>
                <capacities>
                    <li>Cut</li>
                </capacities>
                <power>22.0</power>
                <cooldownTime>2</cooldownTime>
                <armorPenetration>0.35</armorPenetration>
                <linkedBodyPartsGroup>FrontRightClaws</linkedBodyPartsGroup>
            </li>
            <li>
                <capacities>
                    <li>Bite</li>
                </capacities>
                <power>20.0</power>
                <cooldownTime>2.6</cooldownTime>
                <armorPenetration>0.25</armorPenetration>
                <linkedBodyPartsGroup>Teeth</linkedBodyPartsGroup>
                <chanceFactor>0.7</chanceFactor>
            </li>
            <li>
                <label>head</label>
                <capacities>
                    <li>Blunt</li>
                </capacities>
                <power>12</power>
                <cooldownTime>2</cooldownTime>
                <linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
                <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
                <chanceFactor>0.2</chanceFactor>
            </li>
        </tools>
        <race>
            <body>QuadrupedAnimalWithClawsTailAndJowl</body>
            <baseBodySize>2.0</baseBodySize>
            <baseHungerRate>1.0</baseHungerRate>
            <baseHealthScale>2.8</baseHealthScale>
            <foodType>CarnivoreAnimal, OvivoreAnimal</foodType>
            <leatherDef>Leather_Bear</leatherDef>
            <specificMeatDef>FCP_Meat_Prime_Beast</specificMeatDef>
            <gestationPeriodDays>28</gestationPeriodDays>
            <nameOnTameChance>1</nameOnTameChance>
            <trainability>Advanced</trainability>
            <manhunterOnTameFailChance>0.90</manhunterOnTameFailChance>
            <manhunterOnDamageChance>1.0</manhunterOnDamageChance>
            <predator>true</predator>
            <maxPreyBodySize>2.5</maxPreyBodySize>
            <canBePredatorPrey>false</canBePredatorPrey>
            <petness>0.05</petness>
            <soundEating>PredatorLarge_Eat</soundEating>
            <wildBiomes>
                <TemperateForest>0.35</TemperateForest>
                <BorealForest>0.40</BorealForest>
                <TropicalRainforest>0.15</TropicalRainforest>
                <AridShrubland>0.10</AridShrubland>
                <ColdBog>0.20</ColdBog>
            </wildBiomes>
            <litterSizeCurve>
                <points>
                    <li>(0.5, 0)</li>
                    <li>(1, 1)</li>
                    <li>(2, 1.5)</li>
                    <li>(3, 0.7)</li>
                    <li>(3.5, 0)</li>
                </points>
            </litterSizeCurve>
            <lifeExpectancy>22</lifeExpectancy>
            <lifeStageAges>
                <li>
                    <def>AnimalBaby</def>
                    <minAge>0</minAge>
                </li>
                <li>
                    <def>AnimalJuvenile</def>
                    <minAge>0.25</minAge>
                </li>
                <li>
                    <def>AnimalAdult</def>
                    <minAge>1.0</minAge>
                    <soundWounded>FCP_Sound_YaoGuai_Angry</soundWounded>
                    <soundDeath>FCP_Sound_YaoGuai_Death</soundDeath>
                    <soundCall>FCP_Sound_YaoGuai_Call</soundCall>
                    <soundAngry>FCP_Sound_YaoGuai_Angry</soundAngry>
                </li>
            </lifeStageAges>
            <soundMeleeHitPawn>Pawn_Melee_BigBash_HitPawn</soundMeleeHitPawn>
            <soundMeleeHitBuilding>Pawn_Melee_BigBash_HitBuilding</soundMeleeHitBuilding>
            <soundMeleeMiss>Pawn_Melee_BigBash_Miss</soundMeleeMiss>
        </race>
        <tradeTags>
            <li>FCP_Animal_Wild</li>
            <li>FCP_Animal_Dangerous</li>
        </tradeTags>
    </ThingDef>

