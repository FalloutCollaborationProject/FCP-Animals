    <!-- Normal Deathclaw -->

    <ThingDef ParentName="FCP_Animal_Deathclaw_Base">
        <defName>FCP_Animal_Deathclaw</defName>
        <label>Deathclaw</label>
        <description>A large, agile, and powerful creature with deadly claws, the deathclaw is the most fearsome predator of the wasteland. Created through pre-war genetic engineering, these apex predators are incredibly dangerous and nearly impossible to tame. They hunt in packs and can tear through armor with ease.</description>
        <tradeTags>
            <li>FCP_Animal_Deathclaw</li>
        </tradeTags>
    </ThingDef>

    <!-- Alpha Deathclaw -->

